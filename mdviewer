#!/bin/sh
# mdviewer — launch the mdViewer Swing application
#
# Works both when run directly from the project root (development)
# and when installed via install.sh (symlinked from /usr/local/bin).

# Resolve symlinks so DIR always points to the real script location
SCRIPT="$0"
while [ -L "$SCRIPT" ]; do
    SCRIPT="$(readlink "$SCRIPT")"
done
DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"

# Installed JAR sits next to the script; dev JAR is in target/
if [ -f "$DIR/mdviewer.jar" ]; then
    JAR="$DIR/mdviewer.jar"
elif [ -f "$DIR/target/mdviewer.jar" ]; then
    JAR="$DIR/target/mdviewer.jar"
else
    echo "mdviewer: JAR not found. Run install.sh or build with: mvn package" >&2
    exit 1
fi

# Find Java 17+: JAVA_HOME env > Homebrew (Apple Silicon) > Homebrew (Intel) > macOS java_home > PATH
if [ -n "$JAVA_HOME" ] && [ -x "$JAVA_HOME/bin/java" ]; then
    JAVA="$JAVA_HOME/bin/java"
elif [ -x "/opt/homebrew/opt/openjdk/bin/java" ]; then
    JAVA="/opt/homebrew/opt/openjdk/bin/java"
elif [ -x "/usr/local/opt/openjdk/bin/java" ]; then
    JAVA="/usr/local/opt/openjdk/bin/java"
elif /usr/libexec/java_home > /dev/null 2>&1; then
    JAVA="$(/usr/libexec/java_home)/bin/java"
else
    JAVA="java"
fi

exec "$JAVA" \
    --enable-native-access=ALL-UNNAMED \
    -Xdock:name="mdViewer" \
    -Xmx512m \
    -jar "$JAR" \
    "$@"
