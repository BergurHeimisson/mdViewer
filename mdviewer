#!/bin/sh
# mdviewer — launch the mdViewer Swing application
#
# Usage:
#   mdviewer [path/to/file.md]
#
# Place this script (and the project alongside it, or set MDVIEWER_JAR)
# somewhere on your PATH, e.g. /usr/local/bin/.

DIR="$(cd "$(dirname "$0")" && pwd)"
JAR="${MDVIEWER_JAR:-${DIR}/target/mdviewer.jar}"

if [ ! -f "$JAR" ]; then
    echo "mdviewer: JAR not found at $JAR" >&2
    echo "Build first with:  cd \"$DIR\" && mvn package" >&2
    exit 1
fi

JAVA_HOME=/opt/homebrew/Cellar/openjdk/25.0.2/libexec/openjdk.jdk/Contents/Home
exec "$JAVA_HOME/bin/java" \
    --enable-native-access=ALL-UNNAMED \
    -Xdock:name="mdViewer" \
    -Xmx512m \
    -jar "$JAR" \
    "$@"
